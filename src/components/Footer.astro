---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="logo-icon">VDS</span>
          <span class="logo-text">Value Driven Solutions</span>
        </div>
        <p class="footer-tagline">
          Soluciones tecnológicas de vanguardia para la transformación digital de Centro América.
        </p>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <h4 class="footer-heading">Servicios</h4>
          <a href="#servicios">Migración a la Nube</a>
          <a href="#servicios">Ciberseguridad</a>
          <a href="#servicios">Consultoría TI</a>
          <a href="#servicios">Soporte 24/7</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Empresa</h4>
          <a href="#nosotros">Sobre Nosotros</a>
          <a href="#ubicaciones">Ubicaciones</a>
          <a href="#contacto">Contacto</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Value Driven Solutions - Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 4rem 0 0;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    padding-bottom: 3rem;
  }

  .footer-brand {
    max-width: 350px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .footer-logo .logo-icon {
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    color: white;
    font-weight: 700;
    font-size: 0.8rem;
    padding: 0.35rem 0.55rem;
    border-radius: 6px;
    letter-spacing: 0.05em;
  }

  .footer-logo .logo-text {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text-heading);
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .footer-links {
    display: flex;
    gap: 4rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-heading {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-heading);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .footer-col a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .footer-col a:hover {
    color: var(--color-primary-light);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 0;
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      gap: 2.5rem;
    }

    .footer-links {
      gap: 2.5rem;
    }
  }
</style>
