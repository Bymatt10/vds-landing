---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Consumo y Migracion a la Nube',
    description: 'Facilitamos la transicion a infraestructura en la nube, ayudando a las empresas a aprovechar la tecnologia moderna mientras mantenemos la seguridad y accesibilidad de los datos. Guiamos a nuestros clientes a traves de las fases de planificacion y ejecucion.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/><path d="M12 13v6"/><path d="m9 16 3-3 3 3"/></svg>`,
    category: 'Cloud',
  },
  {
    title: 'Licenciamiento y Servicios M365',
    description: 'Soluciones integrales para la gestion y optimizacion de licenciamiento de Microsoft 365. Nuestros servicios mejoran la seguridad, simplifican la administracion y maximizan el uso de herramientas de productividad.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>`,
    category: 'Productividad',
  },
  {
    title: 'CiberSeguridad Avanzada',
    description: 'Proteccion de datos a traves de servicios avanzados de ciberseguridad que resguardan su infraestructura contra amenazas. Ofrecemos auditorias, implementacion de medidas de seguridad y programas de capacitacion para el personal.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
    category: 'Seguridad',
  },
  {
    title: 'Formacion en TI y Capacitacion',
    description: 'Programas de capacitacion personalizados que van desde nivel basico hasta avanzado. Aseguramos que su personal se mantenga actualizado con las tendencias de la industria y tecnologias emergentes.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
    category: 'Capacitacion',
  },
  {
    title: 'Consultoria en Tecnologia',
    description: 'Servicios de consultoria estrategica que analizan las necesidades organizacionales y disenan planes de implementacion alineados. Nos enfocamos en la optimizacion de procesos y el despliegue eficiente de soluciones.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/><path d="M9 21h6"/><path d="M12 18v3"/></svg>`,
    category: 'Consultoria',
  },
  {
    title: 'Proteccion de Datos',
    description: 'Soluciones avanzadas para proteger datos en nubes publicas y centros de datos. Garantizamos seguridad, continuidad operativa y cumplimiento normativo utilizando tecnologia de vanguardia.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>`,
    category: 'Seguridad',
  },
  {
    title: 'Infraestructura Centros de Datos',
    description: 'Soluciones que utilizan las marcas lideres del mercado para infraestructura de centros de datos. Enfasis en rendimiento, escalabilidad y seguridad con soporte experto y sistemas preparados para el futuro.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6" y1="6" y2="6"/><line x1="6" x2="6" y1="18" y2="18"/><line x1="10" x2="16" y1="6" y2="6"/><line x1="10" x2="16" y1="18" y2="18"/></svg>`,
    category: 'Infraestructura',
  },
  {
    title: 'Redes y Telecomunicaciones',
    description: 'Soluciones avanzadas de conectividad que ofrecen sistemas de red seguros, rapidos y escalables para empresas que buscan optimizar su comunicacion y rendimiento.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor"/></svg>`,
    category: 'Infraestructura',
  },
  {
    title: 'Soporte Tecnico 24/7',
    description: 'Soporte tecnico continuo disponible las 24 horas para resolver problemas de infraestructura. Los servicios incluyen asistencia remota y presencial para garantizar la continuidad operativa.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 18.72a9.09 9.09 0 0 0 3.09-4.56A9.09 9.09 0 0 0 21 12a9 9 0 0 0-9-9 9 9 0 0 0-9 9c0 4.97 4.03 9 9 9a9.12 9.12 0 0 0 2.42-.33"/><path d="M13 16h3a2 2 0 0 1 2 2v3"/><path d="M12 8v4l2 2"/></svg>`,
    category: 'Soporte',
  },
];

const stats = [
  { value: '9+', label: 'Servicios especializados' },
  { value: '4', label: 'Paises en Centro America' },
  { value: '24/7', label: 'Soporte continuo' },
];
---

<Layout
  title="Productos y Servicios de TI | VDS - Value Driven Solutions"
  description="Migracion a la nube, Microsoft 365, ciberseguridad avanzada, consultoria tecnologica, proteccion de datos, infraestructura datacenter, redes y soporte tecnico 24/7 en Centro America."
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="page-hero">
      <div class="hero-bg-grid"></div>
      <div class="hero-orb"></div>
      <div class="container hero-content">
        <span class="eyebrow">Portafolio completo</span>
        <h1 class="page-title">Productos y Servicios<br /><span class="title-accent">de Tecnologia</span></h1>
        <p class="page-subtitle">
          Soluciones integrales para impulsar la transformacion digital de su empresa en cada etapa del camino.
        </p>
      </div>
      <div class="hero-clip"></div>
    </section>

    <!-- Stats bar -->
    <div class="stats-bar">
      <div class="container stats-inner">
        {stats.map(stat => (
          <div class="stat-item">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Services grid -->
    <section class="section services-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Nuestros <span class="gradient-text">Servicios</span></h2>
          <p class="section-subtitle">Cada solucion esta disenada para adaptarse a las necesidades especificas de su organizacion.</p>
        </div>

        <div class="services-grid">
          {services.map((service, i) => (
            <div class="service-card">
              <div class="card-top-bar"></div>
              <div class="card-inner">
                <div class="card-header">
                  <div class="icon-wrap" set:html={service.icon} />
                  <span class="service-num">{String(i + 1).padStart(2, '0')}</span>
                </div>
                <span class="service-category">{service.category}</span>
                <h3 class="service-title">{service.title}</h3>
                <p class="service-description">{service.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-box">
          <div class="cta-bg-dots"></div>
          <div class="cta-content">
            <span class="cta-eyebrow">Hablemos de su proyecto</span>
            <h2 class="cta-title">Listo para transformar<br />su infraestructura?</h2>
            <p class="cta-text">Contactenos para una consulta gratuita con nuestro equipo de especialistas.</p>
            <a href="/#contacto" class="cta-btn">
              Contactenos
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ───────────────────────────────────────── */
  .page-hero {
    background: var(--color-primary);
    padding: 11rem 0 7rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px);
    background-size: 36px 36px;
    pointer-events: none;
  }

  .hero-orb {
    position: absolute;
    top: -120px;
    right: -80px;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(36,81,160,0.45) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .hero-clip {
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 60px;
    background: var(--color-bg);
    clip-path: ellipse(55% 100% at 50% 100%);
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 100px;
    padding: 0.3rem 0.9rem;
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.12;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }

  .title-accent {
    color: rgba(255,255,255,0.55);
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.65);
    max-width: 540px;
    line-height: 1.75;
  }

  /* ── Stats bar ──────────────────────────────────── */
  .stats-bar {
    background: #ffffff;
    box-shadow: 0 4px 32px rgba(10,30,61,0.07);
    position: relative;
    z-index: 10;
  }

  .stats-inner {
    display: flex;
    justify-content: center;
    gap: 0;
    padding: 0;
  }

  .stat-item {
    flex: 1;
    max-width: 260px;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1.5rem;
    border-right: 1px solid var(--color-border);
  }

  .stat-item:last-child {
    border-right: none;
  }

  .stat-value {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-primary);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-align: center;
    font-weight: 500;
  }

  /* ── Services grid ──────────────────────────────── */
  .services-section {
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text-heading);
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .service-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    display: flex;
    flex-direction: column;
  }

  .card-top-bar {
    height: 3px;
    background: var(--color-border);
    transition: background var(--transition);
    flex-shrink: 0;
  }

  .service-card:hover {
    transform: translateY(-5px);
    border-color: rgba(10,30,61,0.2);
    box-shadow: 0 16px 48px rgba(10,30,61,0.1);
  }

  .service-card:hover .card-top-bar {
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent-light));
  }

  .card-inner {
    padding: 1.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .icon-wrap {
    width: 44px;
    height: 44px;
    background: var(--color-bg-elevated);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    transition: background var(--transition), color var(--transition);
    flex-shrink: 0;
  }

  .icon-wrap svg {
    width: 22px;
    height: 22px;
  }

  .service-card:hover .icon-wrap {
    background: var(--color-primary);
    color: #ffffff;
  }

  .service-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    opacity: 0.3;
    letter-spacing: 0.05em;
  }

  .service-category {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: 0.6rem;
  }

  .service-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }

  .service-description {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    flex: 1;
  }

  /* ── CTA ────────────────────────────────────────── */
  .cta-section {
    padding: 0 0 5rem;
  }

  .cta-box {
    background: linear-gradient(135deg, var(--color-primary) 0%, #1a3a6b 100%);
    border-radius: 16px;
    padding: 5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  .cta-eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 100px;
    padding: 0.3rem 0.9rem;
    margin-bottom: 1.5rem;
  }

  .cta-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 1rem;
    line-height: 1.2;
    letter-spacing: -0.025em;
  }

  .cta-text {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 2.25rem;
    line-height: 1.7;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2.25rem;
    background: #ffffff;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 8px;
    transition: all 0.3s ease;
    letter-spacing: -0.01em;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
    gap: 0.75rem;
  }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 9rem 0 6rem;
    }

    .stats-inner {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .stat-item {
      flex: 1 1 45%;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding: 1.5rem 1rem;
    }

    .stat-item:last-child {
      border-bottom: none;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .cta-box {
      padding: 3rem 1.75rem;
    }
  }
</style>
