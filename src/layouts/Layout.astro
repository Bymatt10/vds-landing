---
interface Breadcrumb {
  name: string;
  item: string;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: string;
  breadcrumbs?: Breadcrumb[];
  pageSchema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description = 'Value Driven Solutions (VDS) — Empresa de soluciones tecnologicas en Centro America. Migracion a la nube, ciberseguridad, Microsoft 365, consultoria TI, infraestructura datacenter y soporte tecnico 24/7 en Costa Rica, El Salvador, Nicaragua y Guatemala.',
  image = '/og-image.png',
  imageAlt = 'Value Driven Solutions — Soluciones tecnologicas para Centro America',
  type = 'website',
  breadcrumbs,
  pageSchema,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);

// ── Structured Data ────────────────────────────────────────────────────────
const organizationSchema = {
  '@type': 'Organization',
  '@id': 'https://vdstecnologia.com/#organization',
  name: 'Value Driven Solutions',
  alternateName: ['VDS', 'VDS Tecnologia'],
  url: 'https://vdstecnologia.com',
  logo: {
    '@type': 'ImageObject',
    '@id': 'https://vdstecnologia.com/#logo',
    url: 'https://vdstecnologia.com/og-image.png',
    width: 1200,
    height: 630,
  },
  image: 'https://vdstecnologia.com/og-image.png',
  description:
    'Empresa especializada en soluciones tecnologicas de vanguardia para la transformacion digital de empresas en Centro America. Servicios de migracion a la nube, ciberseguridad, Microsoft 365, consultoria TI, infraestructura datacenter y soporte 24/7.',
  areaServed: [
    { '@type': 'Country', name: 'Costa Rica' },
    { '@type': 'Country', name: 'El Salvador' },
    { '@type': 'Country', name: 'Nicaragua' },
    { '@type': 'Country', name: 'Guatemala' },
  ],
  knowsAbout: [
    'Cloud Computing',
    'Migracion a la Nube',
    'Microsoft 365',
    'Ciberseguridad',
    'Consultoria TI',
    'Proteccion de Datos',
    'Infraestructura Datacenter',
    'Redes y Telecomunicaciones',
    'Capacitacion TI',
    'Soporte Tecnico',
    'AWS',
    'Google Cloud',
    'Nutanix',
    'VMware',
    'Veeam',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de TI',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Migracion a la Nube' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Licenciamiento Microsoft 365' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Ciberseguridad Avanzada' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Consultoria en Tecnologia' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Proteccion de Datos' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Infraestructura Centros de Datos' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Redes y Telecomunicaciones' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Formacion en TI y Capacitacion' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Soporte Tecnico 24/7' } },
    ],
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      contactType: 'customer service',
      availableLanguage: ['Spanish'],
      areaServed: ['CR', 'SV', 'NI', 'GT'],
      hoursAvailable: 'Mo-Fr 08:00-17:00',
    },
    {
      '@type': 'ContactPoint',
      contactType: 'technical support',
      availableLanguage: ['Spanish'],
      areaServed: ['CR', 'SV', 'NI', 'GT'],
      hoursAvailable: 'Mo-Su 00:00-24:00',
    },
  ],
  // Update these with real social profile URLs
  sameAs: [
    'https://www.linkedin.com/company/value-driven-solutions',
  ],
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': 'https://vdstecnologia.com/#website',
  url: 'https://vdstecnologia.com',
  name: 'Value Driven Solutions',
  description: 'Soluciones tecnologicas de vanguardia para Centro America',
  publisher: { '@id': 'https://vdstecnologia.com/#organization' },
  inLanguage: 'es',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://vdstecnologia.com/?s={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};

const webPageSchema = {
  '@type': 'WebPage',
  '@id': `${canonicalURL}#webpage`,
  url: canonicalURL,
  name: title,
  description: description,
  isPartOf: { '@id': 'https://vdstecnologia.com/#website' },
  about: { '@id': 'https://vdstecnologia.com/#organization' },
  inLanguage: 'es',
  dateModified: new Date().toISOString(),
};

const breadcrumbSchema = breadcrumbs
  ? {
      '@type': 'BreadcrumbList',
      '@id': `${canonicalURL}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://vdstecnologia.com' },
        ...breadcrumbs.map((bc, i) => ({
          '@type': 'ListItem',
          position: i + 2,
          name: bc.name,
          item: bc.item,
        })),
      ],
    }
  : null;

const graphNodes = [
  organizationSchema,
  websiteSchema,
  webPageSchema,
  breadcrumbSchema,
  ...(Array.isArray(pageSchema) ? pageSchema : pageSchema ? [pageSchema] : []),
].filter(Boolean);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': graphNodes,
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a1e3d" />

    <!-- Resource hints -->
    <link rel="preconnect" href="https://rsms.me" crossorigin />
    <link rel="dns-prefetch" href="https://rsms.me" />
    <link rel="dns-prefetch" href="https://flagcdn.com" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    }
    <meta name="author" content="Value Driven Solutions" />
    <meta name="keywords" content="soluciones tecnologicas centro america, consultoria ti costa rica, migracion nube costa rica, microsoft 365 costa rica, ciberseguridad empresas, soporte tecnico empresas, infraestructura datacenter, redes telecomunicaciones, transformacion digital, aws partner costa rica, vds tecnologia, value driven solutions" />

    <!-- Geo targeting -->
    <meta name="geo.region" content="CR" />
    <meta name="geo.placename" content="San Jose, Costa Rica" />
    <meta name="language" content="es" />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Value Driven Solutions" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:locale:alternate" content="es_SV" />
    <meta property="og:locale:alternate" content="es_NI" />
    <meta property="og:locale:alternate" content="es_GT" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- hreflang: regional targeting for Central America -->
    <link rel="alternate" hreflang="es" href={canonicalURL} />
    <link rel="alternate" hreflang="es-CR" href={canonicalURL} />
    <link rel="alternate" hreflang="es-SV" href={canonicalURL} />
    <link rel="alternate" hreflang="es-NI" href={canonicalURL} />
    <link rel="alternate" hreflang="es-GT" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts -->
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        --font-main: 'Inter', 'InterVariable', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol';
        --font-heading: 'Inter', 'InterDisplay', var(--font-main);
        --color-bg: #ffffff;
        --color-bg-elevated: #f8f9fa;
        --color-bg-card: #ffffff;
        --color-primary: #0a1e3d;
        --color-primary-light: #142d54;
        --color-accent: #1a3a6b;
        --color-accent-light: #2451a0;
        --color-text: #111827;
        --color-text-muted: #4b5563;
        --color-text-heading: #111827;
        --color-border: #e5e7eb;
        --color-gradient-start: #0a1e3d;
        --color-gradient-end: #1a3a6b;
        --max-width: 1200px;
        --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }

      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      @supports (font-variation-settings: normal) {
        :root {
          --font-main: 'InterVariable', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
      }

      html {
        scroll-behavior: smooth;
        text-size-adjust: 100%;
        -webkit-text-size-adjust: 100%;
        font-feature-settings: "cv02", "cv03", "cv04", "cv11";
      }

      body {
        font-family: var(--font-main);
        background-color: var(--color-bg);
        color: var(--color-text);
        line-height: 1.5;
        font-feature-settings: "cv02", "cv03", "cv04", "cv11";
        font-variation-settings: "opsz" 32;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.2;
        color: var(--color-text-heading);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .gradient-text {
        background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .section {
        padding: 5rem 0;
      }

      .section-title {
        font-size: 2.5rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 1rem;
        color: var(--color-text-heading);
      }

      .section-subtitle {
        text-align: center;
        color: var(--color-text-muted);
        font-size: 1.125rem;
        max-width: 600px;
        margin: 0 auto 3rem;
      }

      @media (max-width: 768px) {
        .section {
          padding: 3rem 0;
        }

        .section-title {
          font-size: 1.75rem;
        }

        .section-subtitle {
          font-size: 1rem;
        }
      }

      @media (max-width: 480px) {
        .section {
          padding: 2.5rem 0;
        }

        .section-title {
          font-size: 1.5rem;
        }

        .container {
          padding: 0 1rem;
        }
      }
    </style>
  </body>
</html>
